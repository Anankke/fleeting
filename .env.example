# Required
SESSION_SECRET=change-me-to-a-long-random-string

# PostgreSQL
POSTGRES_USER=peld
POSTGRES_PASSWORD=peld
POSTGRES_DB=peld
DATABASE_URL=postgres://peld:peld@localhost:5432/peld

# Memcached
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# In-house OIDC provider
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=peld-online
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=https://peld.example.com/auth/callback

# Nchan internal publisher (Docker: http://nchan/pub/fleet, local dev: http://localhost/pub/fleet)
NCHAN_PUB_URL=http://localhost/pub/fleet

# ESI
ESI_BASE_URL=https://esi.evetech.net

# Server
PORT=3000
NODE_ENV=development
